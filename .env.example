NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://nax:nax@localhost:5432/nax_api
DB_POOL_MAX=10

JWT_ACCESS_SECRET=replace-this-with-at-least-32-random-characters
